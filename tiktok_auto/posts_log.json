    "comments": 0,
    "last_checked": "2026-04-19T02:56:04.306991",
    "saves": 0,
    "shares": 0
  },
  {
    "id": "20260415_200959",
    "posted_at": "2026-04-15T20:09:59.168038",
    "text": "あの人の好きだったところを、次の人に求めてしまってる気がする。",
    "text_hash": "baeedffc735fb52f80bba12321b6b828",
    "category": "元カレ元カノ",
    "tone": "共感型",
    "format": "独白",
