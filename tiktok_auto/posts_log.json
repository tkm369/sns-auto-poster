    "video_duration": 16.0,
    "views": 406,
    "likes": 7,
    "comments": 0,
    "last_checked": "2026-04-26T03:02:20.792286",
    "saves": 1,
    "shares": 0
  },
  {
    "id": "20260416_172422",
    "posted_at": "2026-04-16T17:24:22.161237",
    "text": "寝る前だけ、少し弱くなっていい気がしてる。",
