    "video_duration": 16.0,
    "views": 352,
    "likes": 5,
    "comments": 0,
    "last_checked": "2026-04-22T04:56:07.278744",
    "saves": 1,
    "shares": 0
  },
  {
    "id": "20260415_210926",
    "posted_at": "2026-04-15T21:09:26.672964",
    "text": "うまくいかなかった恋が、自分を作ってきたと最近思う。",
    "text_hash": "501653d85bb98b069147c0461cda7adf",
    "category": "恋愛名言",
    "tone": "共感型",
    "format": "独白",
