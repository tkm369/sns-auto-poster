    "views": null,
    "likes": null,
    "comments": null,
    "last_checked": null
  },
  {
    "id": "20260412_174000",
    "posted_at": "2026-04-12T17:40:00.387608",
    "text": "友達には「気にしないで」って言うくせに、自分のことになると全然できない。",
    "text_hash": "bbc90309fd862d360edbc39cc21dfed1",
    "category": "恋愛あるある",
    "tone": "共感型",
    "format": "独白",
    "posting_hour": 17,
    "video_duration": 16.0,
    "views": null,
    "likes": null,
    "comments": null,
    "last_checked": null
  },
  {
    "id": "20260412_193744",
    "posted_at": "2026-04-12T19:37:44.353821",
    "text": "好きな人が近くにいると、急に自分が何も話せなくなる。",
    "text_hash": "5cd9f58a3f8e9d68fda2d8a5a5a6ba02",
    "category": "恋愛あるある",
    "tone": "共感型",
    "format": "独白",
    "posting_hour": 19,
    "video_duration": 16.0,
    "views": null,
    "likes": null,
    "comments": null,
    "last_checked": null
  },
  {
    "id": "20260412_201612",
    "posted_at": "2026-04-12T20:16:12.962547",
    "text": "「元気だよ」って返せる自分になってから、連絡しようと思ってた。",
    "text_hash": "833a548a005ea26135d2b6e6d0ac7813",
    "category": "復縁",
    "tone": "共感型",
    "format": "独白",
    "posting_hour": 20,
    "video_duration": 16.0,
    "views": null,
    "likes": null,
    "comments": null,
    "last_checked": null
  },
  {
    "id": "20260413_010229",
    "posted_at": "2026-04-13T01:02:29.822729",
    "text": "一番怖いのは、傷つくことじゃなくて、誰も好きになれなくなることだと気づいた。",
    "text_hash": "fe31a00fb68b518799fd283a3cfc3ac2",
    "category": "恋愛名言",
    "tone": "共感型",
    "format": "独白",
    "posting_hour": 1,
