    "comments": 0,
    "last_checked": "2026-04-26T03:02:20.793286",
    "saves": 2,
    "shares": 0
  },
  {
    "id": "20260416_211459",
    "posted_at": "2026-04-16T21:14:59.757219",
    "text": "好きじゃなくなったんじゃなくて、好きなまま諦めた。",
    "text_hash": "056d08e170bc4985c7c435de6e7715e6",
