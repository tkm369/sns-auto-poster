    "last_checked": "2026-04-26T03:02:20.792286",
    "saves": 0,
    "shares": 0
  },
  {
    "id": "20260415_200959",
    "posted_at": "2026-04-15T20:09:59.168038",
    "text": "あの人の好きだったところを、次の人に求めてしまってる気がする。",
    "text_hash": "baeedffc735fb52f80bba12321b6b828",
    "category": "元カレ元カノ",
    "tone": "共感型",
    "format": "独白",
    "posting_hour": 20,
    "video_duration": 16.0,
    "views": 340,
    "likes": 12,
    "comments": 0,
    "last_checked": "2026-04-26T03:02:20.792286",
    "saves": 1,
    "shares": 0
  },
  {
    "id": "20260415_201604",
    "posted_at": "2026-04-15T20:16:04.319290",
    "text": "その人のことを考えると、自然と口角が上がってるらしい。",
    "text_hash": "12d1ce03ae4fc1dbeb022610f5488079",
    "category": "好きな人",
    "tone": "共感型",
    "format": "独白",
    "posting_hour": 20,
    "video_duration": 16.0,
    "views": 352,
    "likes": 5,
    "comments": 0,
    "last_checked": "2026-04-26T03:02:20.792286",
    "saves": 1,
    "shares": 0
  },
  {
    "id": "20260415_210926",
    "posted_at": "2026-04-15T21:09:26.672964",
    "text": "うまくいかなかった恋が、自分を作ってきたと最近思う。",
    "text_hash": "501653d85bb98b069147c0461cda7adf",
    "category": "恋愛名言",
    "tone": "共感型",
    "format": "独白",
